function logError(src,msg){

  var ss = SpreadsheetApp.getActiveSpreadsheet();

  var shE = ss.getSheetByName('Errors');

  if(!shE){

    shE = ss.insertSheet('Errors');

    shE.appendRow([
      'TS',
      'SOURCE',
      'MESSAGE'
    ]);
  }

  shE.appendRow([
    new Date(),
    src,
    msg
  ]);

}
