function restoreLastBackup(){

  var shB = sh('Backup');

  if(!shB){
    throw 'BACKUP_NOT_FOUND';
  }

  var last =
    shB.getLastRow();

  if(last < 2){
    throw 'BACKUP_EMPTY';
  }

  var r =
    shB
    .getRange(last,1,1,7)
    .getValues()[0];

  s('Config','B3',r[1]);
  s('Config','B5',r[2]);
  s('Config','B7',r[3]);
  s('Config','B8',r[4]);
  s('Config','B12',r[5]);
  s('Config','B23',r[6]);

  logEvent(
    'RESTORE',
    'LAST_BACKUP'
  );
}
